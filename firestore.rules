      && request.resource.data.taskId.size() <= 160
      && request.resource.data.taskName is string
      && request.resource.data.taskName.size() <= 160
      && (!("notificationKind" in request.resource.data) || request.resource.data.notificationKind in ["plannedStart", "missedScheduledTask", "unscheduledGap", "timeGoalComplete"])
      && request.resource.data.eventType in ["plannedStartReminder", "plannedStartReminderSnoozed", "missedScheduledTask", "unscheduledGapReminder", "timeGoalComplete"]
      && (!("baseEventType" in request.resource.data) || request.resource.data.baseEventType in ["plannedStartReminder", "unscheduledGapReminder", "timeGoalComplete"])
      && (!("effectiveEventType" in request.resource.data) || request.resource.data.effectiveEventType in ["plannedStartReminder", "plannedStartReminderSnoozed", "missedScheduledTask", "unscheduledGapReminder", "timeGoalComplete"])
      && request.resource.data.dueAtMs is int
      && request.resource.data.dueAtMs > 0
      && (!("timeGoalMinutes" in request.resource.data) || request.resource.data.timeGoalMinutes == null || request.resource.data.timeGoalMinutes is int)
      && (!("timeGoalPeriod" in request.resource.data) || request.resource.data.timeGoalPeriod == null || request.resource.data.timeGoalPeriod in ["day", "week"])
      && (!("timeGoalGoalMs" in request.resource.data) || request.resource.data.timeGoalGoalMs == null || request.resource.data.timeGoalGoalMs is int)
      && optionalNullableStringMax("timeGoalCompletionDayKey", 40)
      && optionalNullableStringMax("timeGoalCompletionWeekKey", 40)
      && (!("weekStarting" in request.resource.data) || request.resource.data.weekStarting == null || request.resource.data.weekStarting in ["sun", "mon", "tue", "wed", "thu", "fri", "sat"])
      && (!("plannedStartDay" in request.resource.data) || request.resource.data.plannedStartDay == null || request.resource.data.plannedStartDay in ["mon", "tue", "wed", "thu", "fri", "sat", "sun"])
      && (!("plannedStartTime" in request.resource.data) || request.resource.data.plannedStartTime == null || (
        request.resource.data.plannedStartTime is string
        && request.resource.data.plannedStartTime.matches("^([01][0-9]|2[0-3]):[0-5][0-9]$")
      ))
      && (!("plannedStartByDay" in request.resource.data) || request.resource.data.plannedStartByDay == null || request.resource.data.plannedStartByDay is map)
      && (!("plannedStartPushRemindersEnabled" in request.resource.data) || request.resource.data.plannedStartPushRemindersEnabled is bool)
      && request.resource.data.route == "/tasklaunch"
      && (!("snoozedUntilMs" in request.resource.data) || request.resource.data.snoozedUntilMs == null || request.resource.data.snoozedUntilMs is int)
      && (!("sentAtMs" in request.resource.data) || request.resource.data.sentAtMs == null || request.resource.data.sentAtMs is int)
      && (!("sentDueAtMs" in request.resource.data) || request.resource.data.sentDueAtMs == null || request.resource.data.sentDueAtMs is int)
      && (!("missedCheckDueAtMs" in request.resource.data) || request.resource.data.missedCheckDueAtMs == null || request.resource.data.missedCheckDueAtMs is int)
      && (!("missedScheduledStartDueAtMs" in request.resource.data) || request.resource.data.missedScheduledStartDueAtMs == null || request.resource.data.missedScheduledStartDueAtMs is int)
      && (!("nextPlannedStartDueAtMs" in request.resource.data) || request.resource.data.nextPlannedStartDueAtMs == null || request.resource.data.nextPlannedStartDueAtMs is int)
      && (!("lastMissedAtMs" in request.resource.data) || request.resource.data.lastMissedAtMs == null || request.resource.data.lastMissedAtMs is int)
      && (!("lastMissedDueAtMs" in request.resource.data) || request.resource.data.lastMissedDueAtMs == null || request.resource.data.lastMissedDueAtMs is int)
      && (!("lastActionAtMs" in request.resource.data) || request.resource.data.lastActionAtMs == null || request.resource.data.lastActionAtMs is int)
      && optionalNullableStringMax("lastActionByDeviceId", 160)
      && optionalNullableStringMax("lastGapAlertDayKey", 40)
      && (!("lastGapAlertStartMs" in request.resource.data) || request.resource.data.lastGapAlertStartMs == null || request.resource.data.lastGapAlertStartMs is int)
      && (!("lastGapAlertEndMs" in request.resource.data) || request.resource.data.lastGapAlertEndMs == null || request.resource.data.lastGapAlertEndMs is int)
      && optionalNullableStringMax("activeGapDayKey", 40)
      && (!("activeGapStartMs" in request.resource.data) || request.resource.data.activeGapStartMs == null || request.resource.data.activeGapStartMs is int)
      && (!("activeGapEndMs" in request.resource.data) || request.resource.data.activeGapEndMs == null || request.resource.data.activeGapEndMs is int)
      && optionalNullableStringMax("postponedGapDayKey", 40)
      && (!("postponedGapStartMs" in request.resource.data) || request.resource.data.postponedGapStartMs == null || request.resource.data.postponedGapStartMs is int)
      && (!("postponedGapEndMs" in request.resource.data) || request.resource.data.postponedGapEndMs == null || request.resource.data.postponedGapEndMs is int)
      && (!("createdAt" in request.resource.data) || request.resource.data.createdAt != null)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt != null)
      && (!("schemaVersion" in request.resource.data) || request.resource.data.schemaVersion is int)
      && request.resource.data.ownerUid == request.auth.uid
      && scheduleDocId == (request.resource.data.ownerUid + "__" + request.resource.data.taskId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isUserDoc();
      allow delete: if isOwner(userId);
    }

    match /userSubscriptions/{userId} {
      allow read, create, update, delete: if false;
    }

    match /users/{userId}/preferences/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && docId == "v1" && isPreferencesV1();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/dashboard/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && docId == "v1" && isDashboardV1();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/taskUi/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && docId == "v1" && isTaskUiV1();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/holdingSpace/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && docId == "v1" && isHoldingSpaceV1(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/accountState/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && docId == "v1" && isAccountStateV1();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/devices/{deviceId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isDeviceDoc(deviceId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/tasks/{taskId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isTaskDoc();
      allow delete: if isOwner(userId);

      match /history/{entryId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isHistoryDoc();
        allow delete: if isOwner(userId);
      }

      match /activeSession/{sessionId} {
        allow read: if isOwner(userId) && sessionId == "current";
        allow create, update: if isOwner(userId) && sessionId == "current" && isLiveSessionDoc(taskId);
        allow delete: if isOwner(userId) && sessionId == "current";
      }
    }

    match /users/{userId}/historyEntries/{entryId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isHistoryDoc() && request.resource.data.taskId is string;
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/deletedTasks/{taskId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isDeletedTaskDoc();
      allow delete: if isOwner(userId);
    }

    match /friend_requests/{requestId} {
      allow read: if request.auth != null
        && (
          // Existing doc reads by sender/receiver.
          (resource != null && (request.auth.uid == resource.data.senderUid || request.auth.uid == resource.data.receiverUid))
          // Transaction pre-read on a non-existent pending doc for sender/receiver pair.
          || (resource == null && (
            requestId.matches("^pending:" + request.auth.uid + ":[^:]+$")
            || requestId.matches("^pending:[^:]+:" + request.auth.uid + "$")
          ))
        );
      allow create: if false;
      allow update: if isFriendRequestDecisionUpdate() || isFriendRequestRetryUpdate() || isFriendRequestSenderCancelUpdate();
      allow delete: if canDeletePendingFriendRequest();
    }

    match /friendships/{pairId} {
      allow read: if request.auth != null
        && (
          // Existing docs: only members can read.
          (resource != null && request.auth.uid in resource.data.users)
          // Non-existent docs: allow pre-read for own pair-id lookups during approval flow.
          || (resource == null && (
            pairId.matches("^pair:" + request.auth.uid + ":[^:]+$")
            || pairId.matches("^pair:[^:]+:" + request.auth.uid + "$")
          ))
        );
      allow create: if isFriendshipDocCreate();
      allow update: if isFriendshipSelfProfileUpdate();
      allow delete: if request.auth != null
        && resource != null
        && request.auth.uid in resource.data.users;
    }

    match /shared_task_summaries/{shareDocId} {
      allow read: if request.auth != null
        && resource != null
        && (
          request.auth.uid == resource.data.ownerUid
          || request.auth.uid == resource.data.friendUid
        );
      allow create, update: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid
        && isSharedTaskSummaryV1(shareDocId);
      allow delete: if request.auth != null
        && resource != null
        && (
          request.auth.uid == resource.data.ownerUid
          || request.auth.uid == resource.data.friendUid
        );
    }

    match /leaderboardProfiles/{userId} {
      allow read: if request.auth != null;
      allow create: if isOwner(userId) && isLeaderboardProfileDoc(userId);
      allow update: if isOwner(userId) && isLeaderboardProfileDoc(userId);
      allow delete: if isOwner(userId);
    }

    match /userEmailLookup/{emailKey} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    match /usernames/{usernameKey} {
      allow read, create, update, delete: if false;
    }

    match /scheduled_time_goal_pushes/{scheduleDocId} {
      allow read: if request.auth != null
        && (
          (resource != null && resource.data.ownerUid == request.auth.uid)
          || (resource == null && scheduleDocId.matches("^" + request.auth.uid + "__.+$"))
        );
      allow create, update: if request.auth != null
        && isScheduledTimeGoalPushDoc(scheduleDocId);
      allow delete: if request.auth != null
        && resource != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /shared_task_reminder_state/{reminderDocId} {
      allow read, create, update, delete: if false;
    }

    match /feedback_items/{feedbackId} {
      allow read: if request.auth != null && isPublicFeedbackItemReadSafe();
      allow create, update, delete: if false;

      match /votes/{uid} {
        allow read: if false;
        allow create, update, delete: if false;
      }
    }

    match /feedback_private/{feedbackId} {
      allow read, create, update, delete: if false;
    }
  }
}
