rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function onlyKeys(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    function isValidUserPlanValue(value) {
      return value in ["free", "pro"];
    }

    function userPlanIsClientSafe() {
      return !("plan" in request.resource.data)
      || (
        resource == null
          ? request.resource.data.plan == "free"
          : (
            ("plan" in resource.data && request.resource.data.plan == resource.data.plan)
            || (!("plan" in resource.data) && request.resource.data.plan == "free")
          )
      );
    }

    function userPlanUpdatedAtIsClientSafe() {
      return !("planUpdatedAt" in request.resource.data)
      || (
        resource == null
          ? !("plan" in request.resource.data) || request.resource.data.plan == "free"
          : (
            ("planUpdatedAt" in resource.data && request.resource.data.planUpdatedAt == resource.data.planUpdatedAt)
            || (!("planUpdatedAt" in resource.data) && (
              !("plan" in request.resource.data)
              || (
                ("plan" in resource.data && request.resource.data.plan == resource.data.plan)
                || (!("plan" in resource.data) && request.resource.data.plan == "free")
              )
            ))
          )
      );
    }

    function userUsernameIsClientSafe() {
      return !("username" in request.resource.data)
      || (
        resource == null
          ? request.resource.data.username == null
          : (
            ("username" in resource.data && request.resource.data.username == resource.data.username)
            || (!("username" in resource.data) && request.resource.data.username == null)
          )
      );
    }

    function userUsernameKeyIsClientSafe() {
      return !("usernameKey" in request.resource.data)
      || (
        resource == null
          ? request.resource.data.usernameKey == null
          : (
            ("usernameKey" in resource.data && request.resource.data.usernameKey == resource.data.usernameKey)
            || (!("usernameKey" in resource.data) && request.resource.data.usernameKey == null)
          )
      );
    }

    function isUserDoc() {
      return onlyKeys([
        "email",
        "displayName",
        "username",
        "usernameKey",
        "avatarId",
        "avatarCustomSrc",
        "googlePhotoUrl",
        "rankThumbnailSrc",
        "rewardCurrentRankId",
        "rewardTotalXp",
        "plan",
        "planUpdatedAt",
        "createdAt",
        "updatedAt",
        "schemaVersion"
      ])
      && (!("email" in request.resource.data) || request.resource.data.email is string)
      && (!("displayName" in request.resource.data) || request.resource.data.displayName == null || request.resource.data.displayName is string)
      && (!("username" in request.resource.data) || request.resource.data.username == null || request.resource.data.username is string)
      && (!("usernameKey" in request.resource.data) || request.resource.data.usernameKey == null || request.resource.data.usernameKey is string)
      && (!("avatarId" in request.resource.data) || request.resource.data.avatarId is string)
      && (!("avatarCustomSrc" in request.resource.data) || request.resource.data.avatarCustomSrc == null || request.resource.data.avatarCustomSrc is string)
      && (!("googlePhotoUrl" in request.resource.data) || request.resource.data.googlePhotoUrl == null || request.resource.data.googlePhotoUrl is string)
      && (!("rankThumbnailSrc" in request.resource.data) || request.resource.data.rankThumbnailSrc == null || request.resource.data.rankThumbnailSrc is string)
      && (!("rewardCurrentRankId" in request.resource.data) || request.resource.data.rewardCurrentRankId == null || request.resource.data.rewardCurrentRankId is string)
      && (!("rewardTotalXp" in request.resource.data) || request.resource.data.rewardTotalXp is int)
      && (!("plan" in request.resource.data) || isValidUserPlanValue(request.resource.data.plan))
      && (!("planUpdatedAt" in request.resource.data) || request.resource.data.planUpdatedAt is timestamp)
      && (!("createdAt" in request.resource.data) || request.resource.data.createdAt is timestamp)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp)
      && (!("schemaVersion" in request.resource.data) || request.resource.data.schemaVersion is int)
      && userPlanIsClientSafe()
      && userPlanUpdatedAtIsClientSafe()
      && userUsernameIsClientSafe()
      && userUsernameKeyIsClientSafe();
    }

    function isFriendshipProfileValue(value) {
      return value is map
      && value.keys().hasOnly(["alias", "avatarId", "avatarCustomSrc", "googlePhotoUrl", "rankThumbnailSrc", "currentRankId"])
      && (!("alias" in value) || value.alias == null || value.alias is string)
      && (!("avatarId" in value) || value.avatarId == null || value.avatarId is string)
      && (!("avatarCustomSrc" in value) || value.avatarCustomSrc == null || value.avatarCustomSrc is string)
      && (!("googlePhotoUrl" in value) || value.googlePhotoUrl == null || value.googlePhotoUrl is string)
      && (!("rankThumbnailSrc" in value) || value.rankThumbnailSrc == null || value.rankThumbnailSrc is string)
      && (!("currentRankId" in value) || value.currentRankId == null || value.currentRankId is string);
    }

    function isLeaderboardProfileDoc(userId) {
      return onlyKeys([
        "uid",
        "username",
        "displayLabel",
        "avatarId",
        "avatarCustomSrc",
        "googlePhotoUrl",
        "rankThumbnailSrc",
        "rewardCurrentRankId",
        "rewardTotalXp",
        "streakDays",
        "totalFocusMs",
        "weeklyXpGain",
        "updatedAt",
        "schemaVersion"
      ])
      && request.resource.data.uid == userId
      && (!("username" in request.resource.data) || request.resource.data.username == null || request.resource.data.username is string)
      && request.resource.data.displayLabel is string
      && (!("avatarId" in request.resource.data) || request.resource.data.avatarId == null || request.resource.data.avatarId is string)
      && (!("avatarCustomSrc" in request.resource.data) || request.resource.data.avatarCustomSrc == null || request.resource.data.avatarCustomSrc is string)
      && (!("googlePhotoUrl" in request.resource.data) || request.resource.data.googlePhotoUrl == null || request.resource.data.googlePhotoUrl is string)
      && (!("rankThumbnailSrc" in request.resource.data) || request.resource.data.rankThumbnailSrc == null || request.resource.data.rankThumbnailSrc is string)
      && (!("rewardCurrentRankId" in request.resource.data) || request.resource.data.rewardCurrentRankId == null || request.resource.data.rewardCurrentRankId is string)
      && request.resource.data.rewardTotalXp is int
      && request.resource.data.streakDays is int
      && request.resource.data.totalFocusMs is int
      && request.resource.data.weeklyXpGain is int
      && request.resource.data.updatedAt is timestamp
      && request.resource.data.schemaVersion is int;
    }

    function isPreferencesV1() {
      return onlyKeys([
        "schemaVersion",
        "theme",
        "menuButtonStyle",
        "defaultTaskTimerFormat",
        "weekStarting",
        "startupModule",
        "taskView",
        "autoFocusOnTaskLaunchEnabled",
        "mobilePushAlertsEnabled",
        "webPushAlertsEnabled",
        "dynamicColorsEnabled",
        "checkpointAlertSoundEnabled",
        "checkpointAlertToastEnabled",
        "optimalProductivityStartTime",
        "optimalProductivityEndTime",
        "rewards",
        "updatedAtMs",
        "updatedAt"
      ])
      && (!("schemaVersion" in request.resource.data) || request.resource.data.schemaVersion is int)
      && (!("theme" in request.resource.data) || request.resource.data.theme in ["purple", "cyan", "lime"])
      && (!("menuButtonStyle" in request.resource.data) || request.resource.data.menuButtonStyle in ["parallelogram", "square"])
      && (!("defaultTaskTimerFormat" in request.resource.data) || request.resource.data.defaultTaskTimerFormat in ["day", "hour", "minute"])
      && (!("weekStarting" in request.resource.data) || request.resource.data.weekStarting in ["sun", "mon", "tue", "wed", "thu", "fri", "sat"])
      && (!("startupModule" in request.resource.data) || request.resource.data.startupModule in ["dashboard", "tasks", "friends", "leaderboard"])
      && (!("taskView" in request.resource.data) || request.resource.data.taskView in ["list", "tile"])
      && (!("autoFocusOnTaskLaunchEnabled" in request.resource.data) || request.resource.data.autoFocusOnTaskLaunchEnabled is bool)
      && (!("mobilePushAlertsEnabled" in request.resource.data) || request.resource.data.mobilePushAlertsEnabled is bool)
      && (!("webPushAlertsEnabled" in request.resource.data) || request.resource.data.webPushAlertsEnabled is bool)
      && (!("dynamicColorsEnabled" in request.resource.data) || request.resource.data.dynamicColorsEnabled is bool)
      && (!("checkpointAlertSoundEnabled" in request.resource.data) || request.resource.data.checkpointAlertSoundEnabled is bool)
      && (!("checkpointAlertToastEnabled" in request.resource.data) || request.resource.data.checkpointAlertToastEnabled is bool)
      && (!("optimalProductivityStartTime" in request.resource.data) || (
        request.resource.data.optimalProductivityStartTime is string
        && request.resource.data.optimalProductivityStartTime.matches("^([01][0-9]|2[0-3]):[0-5][0-9]$")
      ))
      && (!("optimalProductivityEndTime" in request.resource.data) || (
        request.resource.data.optimalProductivityEndTime is string
        && request.resource.data.optimalProductivityEndTime.matches("^([01][0-9]|2[0-3]):[0-5][0-9]$")
      ))
      && (!("rewards" in request.resource.data) || request.resource.data.rewards is map)
      && (!("updatedAtMs" in request.resource.data) || request.resource.data.updatedAtMs is int)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isDashboardV1() {
      return onlyKeys([
        "schemaVersion",
        "order",
        "widgets",
        "updatedAt"
      ])
      && (!("schemaVersion" in request.resource.data) || request.resource.data.schemaVersion is int)
      && (!("order" in request.resource.data) || request.resource.data.order is list)
      && (!("widgets" in request.resource.data) || request.resource.data.widgets is map)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isTaskUiV1() {
      return onlyKeys([
        "schemaVersion",
        "historyRangeDaysByTaskId",
        "historyRangeModeByTaskId",
        "pinnedHistoryTaskIds",
        "customTaskNames",
        "updatedAt"
      ])
      && (!("schemaVersion" in request.resource.data) || request.resource.data.schemaVersion is int)
      && (!("historyRangeDaysByTaskId" in request.resource.data) || request.resource.data.historyRangeDaysByTaskId is map)
      && (!("historyRangeModeByTaskId" in request.resource.data) || request.resource.data.historyRangeModeByTaskId is map)
      && (!("pinnedHistoryTaskIds" in request.resource.data) || request.resource.data.pinnedHistoryTaskIds is list)
      && (!("customTaskNames" in request.resource.data) || request.resource.data.customTaskNames is list)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isAccountStateV1() {
      return onlyKeys([
        "schemaVersion",
        "friendInviteKey",
        "friendInviteKeyExpiresAt",
        "deleteReauthPending",
        "updatedAt"
      ])
      && (!("schemaVersion" in request.resource.data) || request.resource.data.schemaVersion is int)
      && (!("friendInviteKey" in request.resource.data) || request.resource.data.friendInviteKey == null || request.resource.data.friendInviteKey is string)
      && (!("friendInviteKeyExpiresAt" in request.resource.data) || request.resource.data.friendInviteKeyExpiresAt == null || request.resource.data.friendInviteKeyExpiresAt is int)
      && (!("deleteReauthPending" in request.resource.data) || request.resource.data.deleteReauthPending is bool)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isDeviceDoc() {
        return onlyKeys([
          "token",
          "enabled",
          "platform",
          "provider",
        "channelId",
        "native",
        "appId",
        "appActive",
        "appStateUpdatedAtMs",
          "kind",
          "scope",
          "checkpointAlertMuteTaskId",
          "checkpointAlertMuteAtMs",
          "createdAt",
          "updatedAt"
        ])
      && (!("token" in request.resource.data) || request.resource.data.token is string)
      && (!("enabled" in request.resource.data) || request.resource.data.enabled is bool)
      && (!("platform" in request.resource.data) || request.resource.data.platform is string)
      && (!("provider" in request.resource.data) || request.resource.data.provider is string)
      && (!("channelId" in request.resource.data) || request.resource.data.channelId == null || request.resource.data.channelId is string)
      && (!("native" in request.resource.data) || request.resource.data.native is bool)
      && (!("appId" in request.resource.data) || request.resource.data.appId == null || request.resource.data.appId is string)
      && (!("appActive" in request.resource.data) || request.resource.data.appActive is bool)
      && (!("appStateUpdatedAtMs" in request.resource.data) || request.resource.data.appStateUpdatedAtMs is int)
        && (!("kind" in request.resource.data) || request.resource.data.kind is string)
        && (!("scope" in request.resource.data) || request.resource.data.scope is string)
        && (!("checkpointAlertMuteTaskId" in request.resource.data) || request.resource.data.checkpointAlertMuteTaskId == null || request.resource.data.checkpointAlertMuteTaskId is string)
        && (!("checkpointAlertMuteAtMs" in request.resource.data) || request.resource.data.checkpointAlertMuteAtMs is int)
        && (!("createdAt" in request.resource.data) || request.resource.data.createdAt is timestamp)
        && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp);
      }

    function isTaskDoc() {
      return onlyKeys([
        "id",
        "name",
        "order",
        "collapsed",
        "color",
        "accumulatedMs",
        "running",
        "startMs",
        "hasStarted",
        "checkpointsEnabled",
        "checkpointTimeUnit",
        "checkpoints",
        "milestonesEnabled",
        "milestoneTimeUnit",
        "milestones",
        "checkpointSoundEnabled",
        "checkpointSoundMode",
        "checkpointToastEnabled",
        "checkpointToastMode",
        "timeGoalAction",
        "finalCheckpointAction",
        "xpDisqualifiedUntilReset",
        "presetIntervalsEnabled",
        "presetIntervalValue",
        "presetIntervalLastCheckpointId",
        "presetIntervalLastMilestoneId",
        "presetIntervalNextSeq",
        "timeGoalEnabled",
        "timeGoalValue",
        "timeGoalUnit",
        "timeGoalPeriod",
        "timeGoalMinutes",
        "taskType",
        "onceOffDay",
        "onceOffTargetDate",
        "plannedStartDay",
        "plannedStartTime",
        "plannedStartByDay",
        "plannedStartOpenEnded",
        "plannedStartPushRemindersEnabled",
        "bgTimeGoalPushEligible",
        "bgTimeGoalPushDueAtMs",
        "bgTimeGoalPushSentAtMs",
        "bgTimeGoalPushSentDueAtMs",
        "createdAt",
        "updatedAt",
        "schemaVersion"
      ])
      && (!("id" in request.resource.data) || request.resource.data.id is string)
      && (!("name" in request.resource.data) || request.resource.data.name is string)
      && (!("order" in request.resource.data) || request.resource.data.order is int)
      && (!("collapsed" in request.resource.data) || request.resource.data.collapsed is bool)
      && (!("color" in request.resource.data) || request.resource.data.color == null || request.resource.data.color is string)
      && (!("accumulatedMs" in request.resource.data) || request.resource.data.accumulatedMs is int)
      && (!("running" in request.resource.data) || request.resource.data.running is bool)
      && (!("startMs" in request.resource.data) || request.resource.data.startMs == null || request.resource.data.startMs is int)
      && (!("hasStarted" in request.resource.data) || request.resource.data.hasStarted is bool)
      && (!("checkpointsEnabled" in request.resource.data) || request.resource.data.checkpointsEnabled is bool)
      && (!("checkpointTimeUnit" in request.resource.data) || request.resource.data.checkpointTimeUnit in ["day", "hour", "minute"])
      && (!("checkpoints" in request.resource.data) || request.resource.data.checkpoints is list)
      && (!("milestonesEnabled" in request.resource.data) || request.resource.data.milestonesEnabled is bool)
      && (!("milestoneTimeUnit" in request.resource.data) || request.resource.data.milestoneTimeUnit in ["day", "hour", "minute"])
      && (!("milestones" in request.resource.data) || request.resource.data.milestones is list)
      && (!("checkpointSoundEnabled" in request.resource.data) || request.resource.data.checkpointSoundEnabled is bool)
      && (!("checkpointSoundMode" in request.resource.data) || request.resource.data.checkpointSoundMode in ["once", "repeat"])
      && (!("checkpointToastEnabled" in request.resource.data) || request.resource.data.checkpointToastEnabled is bool)
      && (!("checkpointToastMode" in request.resource.data) || request.resource.data.checkpointToastMode in ["auto5s", "auto3s", "manual"])
      && (!("timeGoalAction" in request.resource.data) || request.resource.data.timeGoalAction in ["continue", "resetLog", "resetNoLog", "confirmModal"])
      && (!("finalCheckpointAction" in request.resource.data) || request.resource.data.finalCheckpointAction in ["continue", "resetLog", "resetNoLog", "confirmModal"])
      && (!("xpDisqualifiedUntilReset" in request.resource.data) || request.resource.data.xpDisqualifiedUntilReset is bool)
      && (!("presetIntervalsEnabled" in request.resource.data) || request.resource.data.presetIntervalsEnabled is bool)
      && (!("presetIntervalValue" in request.resource.data) || request.resource.data.presetIntervalValue is int || request.resource.data.presetIntervalValue is float)
      && (!("presetIntervalLastCheckpointId" in request.resource.data) || request.resource.data.presetIntervalLastCheckpointId == null || request.resource.data.presetIntervalLastCheckpointId is string)
      && (!("presetIntervalLastMilestoneId" in request.resource.data) || request.resource.data.presetIntervalLastMilestoneId == null || request.resource.data.presetIntervalLastMilestoneId is string)
      && (!("presetIntervalNextSeq" in request.resource.data) || request.resource.data.presetIntervalNextSeq is int)
      && (!("timeGoalEnabled" in request.resource.data) || request.resource.data.timeGoalEnabled is bool)
      && (!("timeGoalValue" in request.resource.data) || request.resource.data.timeGoalValue is int || request.resource.data.timeGoalValue is float)
      && (!("timeGoalUnit" in request.resource.data) || request.resource.data.timeGoalUnit in ["minute", "hour"])
      && (!("timeGoalPeriod" in request.resource.data) || request.resource.data.timeGoalPeriod in ["day", "week"])
      && (!("timeGoalMinutes" in request.resource.data) || request.resource.data.timeGoalMinutes is int || request.resource.data.timeGoalMinutes is float)
      && (!("taskType" in request.resource.data) || request.resource.data.taskType in ["recurring", "once-off"])
      && (!("onceOffDay" in request.resource.data) || request.resource.data.onceOffDay == null || request.resource.data.onceOffDay in ["mon", "tue", "wed", "thu", "fri", "sat", "sun"])
      && (!("onceOffTargetDate" in request.resource.data) || request.resource.data.onceOffTargetDate == null || request.resource.data.onceOffTargetDate is string)
      && (!("plannedStartDay" in request.resource.data) || request.resource.data.plannedStartDay == null || request.resource.data.plannedStartDay in ["mon", "tue", "wed", "thu", "fri", "sat", "sun"])
      && (!("plannedStartTime" in request.resource.data) || request.resource.data.plannedStartTime == null || request.resource.data.plannedStartTime is string)
      && (!("plannedStartByDay" in request.resource.data) || request.resource.data.plannedStartByDay == null || request.resource.data.plannedStartByDay is map)
      && (!("plannedStartOpenEnded" in request.resource.data) || request.resource.data.plannedStartOpenEnded is bool)
      && (!("plannedStartPushRemindersEnabled" in request.resource.data) || request.resource.data.plannedStartPushRemindersEnabled is bool)
      && (!("bgTimeGoalPushEligible" in request.resource.data) || request.resource.data.bgTimeGoalPushEligible is bool)
      && (!("bgTimeGoalPushDueAtMs" in request.resource.data) || request.resource.data.bgTimeGoalPushDueAtMs == null || request.resource.data.bgTimeGoalPushDueAtMs is int)
      && (!("bgTimeGoalPushSentAtMs" in request.resource.data) || request.resource.data.bgTimeGoalPushSentAtMs == null || request.resource.data.bgTimeGoalPushSentAtMs is int)
      && (!("bgTimeGoalPushSentDueAtMs" in request.resource.data) || request.resource.data.bgTimeGoalPushSentDueAtMs == null || request.resource.data.bgTimeGoalPushSentDueAtMs is int)
      && (!("createdAt" in request.resource.data) || request.resource.data.createdAt is timestamp)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp)
      && (!("schemaVersion" in request.resource.data) || request.resource.data.schemaVersion is int);
    }

    function isHistoryDoc() {
      return onlyKeys([
        "ts",
        "name",
        "ms",
        "color",
        "note",
        "xpDisqualifiedUntilReset",
        "completionDifficulty",
        "createdAt"
      ])
      && (!("ts" in request.resource.data) || request.resource.data.ts is int)
      && (!("name" in request.resource.data) || request.resource.data.name is string)
      && (!("ms" in request.resource.data) || request.resource.data.ms is int)
      && (!("color" in request.resource.data) || request.resource.data.color == null || request.resource.data.color is string)
      && (!("note" in request.resource.data) || request.resource.data.note == null || request.resource.data.note is string)
      && (!("xpDisqualifiedUntilReset" in request.resource.data) || request.resource.data.xpDisqualifiedUntilReset is bool)
      && (!("completionDifficulty" in request.resource.data) || (
        request.resource.data.completionDifficulty is int
        && request.resource.data.completionDifficulty in [1, 2, 3, 4, 5]
      ))
      && (!("createdAt" in request.resource.data) || request.resource.data.createdAt is timestamp);
    }

    function isDeletedTaskDoc() {
      return onlyKeys([
        "name",
        "color",
        "deletedAt",
        "updatedAt"
      ])
      && (!("name" in request.resource.data) || request.resource.data.name is string)
      && (!("color" in request.resource.data) || request.resource.data.color == null || request.resource.data.color is string)
      && (!("deletedAt" in request.resource.data) || request.resource.data.deletedAt is int)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isFriendRequestDocShape() {
      return onlyKeys([
        "requestId",
        "senderUid",
        "receiverUid",
        "senderEmail",
        "receiverEmail",
        "senderAlias",
        "senderAvatarId",
        "senderRankThumbnailSrc",
        "senderCurrentRankId",
        "receiverAlias",
        "receiverAvatarId",
        "receiverRankThumbnailSrc",
        "receiverCurrentRankId",
        "status",
        "createdAt",
        "updatedAt",
        "respondedAt",
        "respondedBy"
      ])
      && (!("requestId" in request.resource.data) || request.resource.data.requestId is string)
      && (!("senderUid" in request.resource.data) || request.resource.data.senderUid is string)
      && (!("receiverUid" in request.resource.data) || request.resource.data.receiverUid is string)
      && (!("senderEmail" in request.resource.data) || request.resource.data.senderEmail == null || request.resource.data.senderEmail is string)
      && (!("receiverEmail" in request.resource.data) || request.resource.data.receiverEmail == null || request.resource.data.receiverEmail is string)
      && (!("senderAlias" in request.resource.data) || request.resource.data.senderAlias == null || request.resource.data.senderAlias is string)
      && (!("senderAvatarId" in request.resource.data) || request.resource.data.senderAvatarId == null || request.resource.data.senderAvatarId is string)
      && (!("senderRankThumbnailSrc" in request.resource.data) || request.resource.data.senderRankThumbnailSrc == null || request.resource.data.senderRankThumbnailSrc is string)
      && (!("senderCurrentRankId" in request.resource.data) || request.resource.data.senderCurrentRankId == null || request.resource.data.senderCurrentRankId is string)
      && (!("receiverAlias" in request.resource.data) || request.resource.data.receiverAlias == null || request.resource.data.receiverAlias is string)
      && (!("receiverAvatarId" in request.resource.data) || request.resource.data.receiverAvatarId == null || request.resource.data.receiverAvatarId is string)
      && (!("receiverRankThumbnailSrc" in request.resource.data) || request.resource.data.receiverRankThumbnailSrc == null || request.resource.data.receiverRankThumbnailSrc is string)
      && (!("receiverCurrentRankId" in request.resource.data) || request.resource.data.receiverCurrentRankId == null || request.resource.data.receiverCurrentRankId is string)
      && (!("status" in request.resource.data) || request.resource.data.status in ["pending", "approved", "declined"])
      && (!("createdAt" in request.resource.data) || request.resource.data.createdAt != null)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt != null)
      && (!("respondedAt" in request.resource.data) || request.resource.data.respondedAt == null || request.resource.data.respondedAt != null)
      && (!("respondedBy" in request.resource.data) || request.resource.data.respondedBy == null || request.resource.data.respondedBy is string);
    }

    function isFriendRequestDecisionUpdate() {
      return isFriendRequestDocShape()
      && request.auth != null
      && request.auth.uid == resource.data.receiverUid
      && resource.data.status == "pending"
      && request.resource.data.status in ["approved", "declined"]
      && request.resource.data.requestId == resource.data.requestId
      && request.resource.data.senderUid == resource.data.senderUid
      && request.resource.data.receiverUid == resource.data.receiverUid
      && request.resource.data.senderEmail == resource.data.senderEmail
      && request.resource.data.receiverEmail == resource.data.receiverEmail
      && request.resource.data.senderAlias == resource.data.senderAlias
      && request.resource.data.senderAvatarId == resource.data.senderAvatarId
      && request.resource.data.senderRankThumbnailSrc == resource.data.senderRankThumbnailSrc
      && request.resource.data.senderCurrentRankId == resource.data.senderCurrentRankId
      && request.resource.data.receiverAlias == resource.data.receiverAlias
      && request.resource.data.receiverAvatarId == resource.data.receiverAvatarId
      && request.resource.data.receiverRankThumbnailSrc == resource.data.receiverRankThumbnailSrc
      && request.resource.data.receiverCurrentRankId == resource.data.receiverCurrentRankId
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.respondedBy == request.auth.uid
      && request.resource.data.respondedAt is timestamp;
    }

    function isFriendRequestRetryUpdate() {
      return isFriendRequestDocShape()
      && request.auth != null
      && request.auth.uid == resource.data.senderUid
      && resource.data.status in ["approved", "declined"]
      && request.resource.data.status == "pending"
      && request.resource.data.requestId == resource.data.requestId
      && request.resource.data.senderUid == resource.data.senderUid
      && request.resource.data.receiverUid == resource.data.receiverUid
      && request.resource.data.senderEmail == resource.data.senderEmail
      && request.resource.data.receiverEmail == resource.data.receiverEmail
      && request.resource.data.senderAlias == resource.data.senderAlias
      && request.resource.data.senderAvatarId == resource.data.senderAvatarId
      && request.resource.data.senderRankThumbnailSrc == resource.data.senderRankThumbnailSrc
      && request.resource.data.senderCurrentRankId == resource.data.senderCurrentRankId
      && request.resource.data.receiverAlias == resource.data.receiverAlias
      && request.resource.data.receiverAvatarId == resource.data.receiverAvatarId
      && request.resource.data.receiverRankThumbnailSrc == resource.data.receiverRankThumbnailSrc
      && request.resource.data.receiverCurrentRankId == resource.data.receiverCurrentRankId
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.respondedBy == null
      && request.resource.data.respondedAt == null;
    }

    function isFriendRequestSenderCancelUpdate() {
      return isFriendRequestDocShape()
      && request.auth != null
      && request.auth.uid == resource.data.senderUid
      && resource.data.status == "pending"
      && request.resource.data.status == "declined"
      && request.resource.data.requestId == resource.data.requestId
      && request.resource.data.senderUid == resource.data.senderUid
      && request.resource.data.receiverUid == resource.data.receiverUid
      && request.resource.data.senderEmail == resource.data.senderEmail
      && request.resource.data.receiverEmail == resource.data.receiverEmail
      && request.resource.data.senderAlias == resource.data.senderAlias
      && request.resource.data.senderAvatarId == resource.data.senderAvatarId
      && request.resource.data.senderRankThumbnailSrc == resource.data.senderRankThumbnailSrc
      && request.resource.data.senderCurrentRankId == resource.data.senderCurrentRankId
      && request.resource.data.receiverAlias == resource.data.receiverAlias
      && request.resource.data.receiverAvatarId == resource.data.receiverAvatarId
      && request.resource.data.receiverRankThumbnailSrc == resource.data.receiverRankThumbnailSrc
      && request.resource.data.receiverCurrentRankId == resource.data.receiverCurrentRankId
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.respondedBy == request.auth.uid
      && request.resource.data.respondedAt is timestamp;
    }

    function canDeletePendingFriendRequest() {
      return request.auth != null
      && resource != null
      && request.auth.uid == resource.data.senderUid
      && resource.data.status == "pending";
    }

    function isFriendshipDocCreate() {
      return onlyKeys([
        "pairId",
        "users",
        "profileByUid",
        "createdAt",
        "createdBy"
      ])
      && request.resource.data.keys().hasAll([
        "pairId",
        "users",
        "profileByUid",
        "createdAt",
        "createdBy"
      ])
      && request.auth != null
      && request.resource.data.pairId is string
      && request.resource.data.users is list
      && request.resource.data.users.size() == 2
      && request.resource.data.users[0] is string
      && request.resource.data.users[1] is string
      && request.resource.data.users[0] != request.resource.data.users[1]
      && request.auth.uid in request.resource.data.users
      && request.resource.data.profileByUid is map
      && request.resource.data.profileByUid[request.resource.data.users[0]] is map
      && request.resource.data.profileByUid[request.resource.data.users[1]] is map
      && isFriendshipProfileValue(request.resource.data.profileByUid[request.resource.data.users[0]])
      && isFriendshipProfileValue(request.resource.data.profileByUid[request.resource.data.users[1]])
      && request.resource.data.createdAt is timestamp
      && request.resource.data.createdBy is string
      && (
        (
          request.resource.data.users[0] < request.resource.data.users[1]
          && request.resource.data.pairId == ("pair:" + request.resource.data.users[0] + ":" + request.resource.data.users[1])
        )
        || (
          request.resource.data.users[1] < request.resource.data.users[0]
          && request.resource.data.pairId == ("pair:" + request.resource.data.users[1] + ":" + request.resource.data.users[0])
        )
      );
    }

    function isFriendshipSelfProfileUpdate() {
      return request.auth != null
      && resource != null
      && request.auth.uid in resource.data.users
      && request.resource.data.pairId == resource.data.pairId
      && request.resource.data.users == resource.data.users
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.createdBy == resource.data.createdBy
      && request.resource.data.profileByUid is map
      && request.resource.data.profileByUid.keys().hasOnly(resource.data.users)
      && isFriendshipProfileValue(request.resource.data.profileByUid[request.auth.uid])
      && (
        request.auth.uid == resource.data.users[0]
          ? request.resource.data.profileByUid[resource.data.users[1]] == resource.data.profileByUid[resource.data.users[1]]
          : request.resource.data.profileByUid[resource.data.users[0]] == resource.data.profileByUid[resource.data.users[0]]
      );
    }

    function friendshipPairId(uidA, uidB) {
      return uidA < uidB
        ? ("pair:" + uidA + ":" + uidB)
        : ("pair:" + uidB + ":" + uidA);
    }

    function friendshipExists(uidA, uidB) {
      return exists(/databases/$(database)/documents/friendships/$(friendshipPairId(uidA, uidB)));
    }

    function isSharedTaskSummaryV1(shareDocId) {
      return onlyKeys([
        "shareDocId",
        "ownerUid",
        "friendUid",
        "taskId",
        "taskName",
        "timerState",
        "focusTrend7dMs",
        "checkpointScaleMs",
        "taskCreatedAtMs",
        "avgTimeLoggedThisWeekMs",
        "totalTimeLoggedMs",
        "sharedAt",
        "updatedAt",
        "schemaVersion"
      ])
      && request.resource.data.keys().hasAll([
        "shareDocId",
        "ownerUid",
        "friendUid",
        "taskId",
        "taskName",
        "timerState",
        "focusTrend7dMs",
        "checkpointScaleMs",
        "taskCreatedAtMs",
        "avgTimeLoggedThisWeekMs",
        "totalTimeLoggedMs",
        "sharedAt",
        "updatedAt",
        "schemaVersion"
      ])
      && request.resource.data.shareDocId is string
      && request.resource.data.ownerUid is string
      && request.resource.data.friendUid is string
      && request.resource.data.taskId is string
      && request.resource.data.taskName is string
      && request.resource.data.timerState in ["running", "stopped"]
      && request.resource.data.focusTrend7dMs is list
      && request.resource.data.focusTrend7dMs.size() == 7
      && request.resource.data.focusTrend7dMs[0] is int
      && request.resource.data.focusTrend7dMs[1] is int
      && request.resource.data.focusTrend7dMs[2] is int
      && request.resource.data.focusTrend7dMs[3] is int
      && request.resource.data.focusTrend7dMs[4] is int
      && request.resource.data.focusTrend7dMs[5] is int
      && request.resource.data.focusTrend7dMs[6] is int
      && (request.resource.data.checkpointScaleMs == null || request.resource.data.checkpointScaleMs is int)
      && (request.resource.data.taskCreatedAtMs == null || request.resource.data.taskCreatedAtMs is int)
      && request.resource.data.avgTimeLoggedThisWeekMs is int
      && request.resource.data.totalTimeLoggedMs is int
      && request.resource.data.sharedAt is timestamp
      && request.resource.data.updatedAt is timestamp
      && request.resource.data.schemaVersion is int
      && request.resource.data.ownerUid != request.resource.data.friendUid
      && request.resource.data.shareDocId == shareDocId
      && request.resource.data.shareDocId == ("share:" + request.resource.data.ownerUid + ":" + request.resource.data.friendUid + ":" + request.resource.data.taskId)
      && friendshipExists(request.resource.data.ownerUid, request.resource.data.friendUid);
    }

    function isScheduledTimeGoalPushDoc(scheduleDocId) {
      return onlyKeys([
        "ownerUid",
        "taskId",
        "taskName",
        "notificationKind",
        "eventType",
        "baseEventType",
        "effectiveEventType",
        "dueAtMs",
        "timeGoalMinutes",
        "plannedStartDay",
        "plannedStartTime",
        "plannedStartByDay",
        "plannedStartPushRemindersEnabled",
        "route",
        "snoozedUntilMs",
        "sentAtMs",
        "sentDueAtMs",
        "lastActionAtMs",
        "lastActionByDeviceId",
        "lastGapAlertDayKey",
        "lastGapAlertStartMs",
        "lastGapAlertEndMs",
        "activeGapDayKey",
        "activeGapStartMs",
        "activeGapEndMs",
        "postponedGapDayKey",
        "postponedGapStartMs",
        "postponedGapEndMs",
        "createdAt",
        "updatedAt",
        "schemaVersion"
      ])
      && request.resource.data.ownerUid is string
      && request.resource.data.taskId is string
      && request.resource.data.taskName is string
      && (!("notificationKind" in request.resource.data) || request.resource.data.notificationKind is string)
      && request.resource.data.eventType is string
      && (!("baseEventType" in request.resource.data) || request.resource.data.baseEventType is string)
      && (!("effectiveEventType" in request.resource.data) || request.resource.data.effectiveEventType is string)
      && request.resource.data.dueAtMs is int
      && (!("timeGoalMinutes" in request.resource.data) || request.resource.data.timeGoalMinutes == null || request.resource.data.timeGoalMinutes is int)
      && (!("plannedStartDay" in request.resource.data) || request.resource.data.plannedStartDay == null || request.resource.data.plannedStartDay in ["mon", "tue", "wed", "thu", "fri", "sat", "sun"])
      && (!("plannedStartTime" in request.resource.data) || request.resource.data.plannedStartTime == null || request.resource.data.plannedStartTime is string)
      && (!("plannedStartByDay" in request.resource.data) || request.resource.data.plannedStartByDay == null || request.resource.data.plannedStartByDay is map)
      && (!("plannedStartPushRemindersEnabled" in request.resource.data) || request.resource.data.plannedStartPushRemindersEnabled is bool)
      && request.resource.data.route is string
      && (!("snoozedUntilMs" in request.resource.data) || request.resource.data.snoozedUntilMs == null || request.resource.data.snoozedUntilMs is int)
      && (!("sentAtMs" in request.resource.data) || request.resource.data.sentAtMs == null || request.resource.data.sentAtMs is int)
      && (!("sentDueAtMs" in request.resource.data) || request.resource.data.sentDueAtMs == null || request.resource.data.sentDueAtMs is int)
      && (!("lastActionAtMs" in request.resource.data) || request.resource.data.lastActionAtMs == null || request.resource.data.lastActionAtMs is int)
      && (!("lastActionByDeviceId" in request.resource.data) || request.resource.data.lastActionByDeviceId == null || request.resource.data.lastActionByDeviceId is string)
      && (!("lastGapAlertDayKey" in request.resource.data) || request.resource.data.lastGapAlertDayKey == null || request.resource.data.lastGapAlertDayKey is string)
      && (!("lastGapAlertStartMs" in request.resource.data) || request.resource.data.lastGapAlertStartMs == null || request.resource.data.lastGapAlertStartMs is int)
      && (!("lastGapAlertEndMs" in request.resource.data) || request.resource.data.lastGapAlertEndMs == null || request.resource.data.lastGapAlertEndMs is int)
      && (!("activeGapDayKey" in request.resource.data) || request.resource.data.activeGapDayKey == null || request.resource.data.activeGapDayKey is string)
      && (!("activeGapStartMs" in request.resource.data) || request.resource.data.activeGapStartMs == null || request.resource.data.activeGapStartMs is int)
      && (!("activeGapEndMs" in request.resource.data) || request.resource.data.activeGapEndMs == null || request.resource.data.activeGapEndMs is int)
      && (!("postponedGapDayKey" in request.resource.data) || request.resource.data.postponedGapDayKey == null || request.resource.data.postponedGapDayKey is string)
      && (!("postponedGapStartMs" in request.resource.data) || request.resource.data.postponedGapStartMs == null || request.resource.data.postponedGapStartMs is int)
      && (!("postponedGapEndMs" in request.resource.data) || request.resource.data.postponedGapEndMs == null || request.resource.data.postponedGapEndMs is int)
      && (!("createdAt" in request.resource.data) || request.resource.data.createdAt != null)
      && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt != null)
      && (!("schemaVersion" in request.resource.data) || request.resource.data.schemaVersion is int)
      && request.resource.data.ownerUid == request.auth.uid
      && scheduleDocId == (request.resource.data.ownerUid + "__" + request.resource.data.taskId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isUserDoc();
      allow delete: if isOwner(userId);
    }

    match /userSubscriptions/{userId} {
      allow read, create, update, delete: if false;
    }

    match /users/{userId}/preferences/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && docId == "v1" && isPreferencesV1();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/dashboard/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && docId == "v1" && isDashboardV1();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/taskUi/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && docId == "v1" && isTaskUiV1();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/accountState/{docId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && docId == "v1" && isAccountStateV1();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/devices/{deviceId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isDeviceDoc();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/tasks/{taskId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isTaskDoc();
      allow delete: if isOwner(userId);

      match /history/{entryId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isHistoryDoc();
        allow delete: if isOwner(userId);
      }
    }

    match /users/{userId}/deletedTasks/{taskId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isDeletedTaskDoc();
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/archieDrafts/{draftId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;
    }

    match /users/{userId}/archieSessions/{sessionId} {
      allow read: if isOwner(userId);
      allow create, update, delete: if false;

      match /events/{eventId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    match /friend_requests/{requestId} {
      allow read: if request.auth != null
        && (
          // Existing doc reads by sender/receiver.
          (resource != null && (request.auth.uid == resource.data.senderUid || request.auth.uid == resource.data.receiverUid))
          // Transaction pre-read on a non-existent pending doc for sender/receiver pair.
          || (resource == null && (
            requestId.matches("^pending:" + request.auth.uid + ":[^:]+$")
            || requestId.matches("^pending:[^:]+:" + request.auth.uid + "$")
          ))
        );
      allow create: if false;
      allow update: if isFriendRequestDecisionUpdate() || isFriendRequestRetryUpdate() || isFriendRequestSenderCancelUpdate();
      allow delete: if canDeletePendingFriendRequest();
    }

    match /friendships/{pairId} {
      allow read: if request.auth != null
        && (
          // Existing docs: only members can read.
          (resource != null && request.auth.uid in resource.data.users)
          // Non-existent docs: allow pre-read for own pair-id lookups during approval flow.
          || (resource == null && (
            pairId.matches("^pair:" + request.auth.uid + ":[^:]+$")
            || pairId.matches("^pair:[^:]+:" + request.auth.uid + "$")
          ))
        );
      allow create: if isFriendshipDocCreate();
      allow update: if isFriendshipSelfProfileUpdate();
      allow delete: if request.auth != null
        && resource != null
        && request.auth.uid in resource.data.users;
    }

    match /shared_task_summaries/{shareDocId} {
      allow read: if request.auth != null
        && resource != null
        && (
          request.auth.uid == resource.data.ownerUid
          || request.auth.uid == resource.data.friendUid
        );
      allow create, update: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid
        && isSharedTaskSummaryV1(shareDocId);
      allow delete: if request.auth != null
        && resource != null
        && (
          request.auth.uid == resource.data.ownerUid
          || request.auth.uid == resource.data.friendUid
        );
    }

    match /leaderboardProfiles/{userId} {
      allow read: if request.auth != null;
      allow create, update: if isOwner(userId) && isLeaderboardProfileDoc(userId);
      allow delete: if isOwner(userId);
    }

    match /userEmailLookup/{emailKey} {
      allow read: if false;
      allow create, update, delete: if false;
    }

    match /usernames/{usernameKey} {
      allow read, create, update, delete: if false;
    }

    match /scheduled_time_goal_pushes/{scheduleDocId} {
      allow read: if request.auth != null
        && (
          (resource != null && resource.data.ownerUid == request.auth.uid)
          || (resource == null && scheduleDocId.matches("^" + request.auth.uid + "__.+$"))
        );
      allow create, update: if request.auth != null
        && isScheduledTimeGoalPushDoc(scheduleDocId);
      allow delete: if request.auth != null
        && resource != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /feedback_items/{feedbackId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;

      match /votes/{uid} {
        allow read: if request.auth != null;
        allow create, update, delete: if false;
      }
    }
  }
}

