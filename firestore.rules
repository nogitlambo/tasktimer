      && request.resource.data.timerState in ["running", "stopped"]
      && request.resource.data.focusTrend7dMs is list
      && request.resource.data.focusTrend7dMs.size() == 7
      && request.resource.data.focusTrend7dMs[0] is int
      && request.resource.data.focusTrend7dMs[1] is int
      && request.resource.data.focusTrend7dMs[2] is int
      && request.resource.data.focusTrend7dMs[3] is int
      && request.resource.data.focusTrend7dMs[4] is int
      && request.resource.data.focusTrend7dMs[5] is int
