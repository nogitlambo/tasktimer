    function friendRequestNotificationDeliveryModeUnchanged() {
      return (
        !("notificationDeliveryMode" in resource.data)
        && !("notificationDeliveryMode" in request.resource.data)
      )
      || (
        "notificationDeliveryMode" in resource.data
        && "notificationDeliveryMode" in request.resource.data
        && request.resource.data.notificationDeliveryMode == resource.data.notificationDeliveryMode
