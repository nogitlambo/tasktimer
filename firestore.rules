    function canDeletePendingFriendRequest() {
      return request.auth != null
      && resource != null
      && request.auth.uid == resource.data.senderUid
      && resource.data.status == "pending";
    }

    function isFriendshipDocCreate() {
      return onlyKeys([
        "pairId",
        "users",
        "profileByUid",
        "createdAt",
        "createdBy"
      ])
      && request.resource.data.keys().hasAll([
        "pairId",
        "users",
        "profileByUid",
        "createdAt",
        "createdBy"
      ])
      && request.auth != null
      && request.resource.data.pairId is string
      && request.resource.data.users is list
      && request.resource.data.users.size() == 2
      && request.resource.data.users[0] is string
      && request.resource.data.users[1] is string
      && request.resource.data.users[0] != request.resource.data.users[1]
      && request.auth.uid in request.resource.data.users
      && request.resource.data.profileByUid is map
      && request.resource.data.profileByUid[request.resource.data.users[0]] is map
      && request.resource.data.profileByUid[request.resource.data.users[1]] is map
      && isFriendshipProfileValue(request.resource.data.profileByUid[request.resource.data.users[0]])
      && isFriendshipProfileValue(request.resource.data.profileByUid[request.resource.data.users[1]])
      && request.resource.data.createdAt is timestamp
      && request.resource.data.createdBy is string
      && request.resource.data.createdBy == request.auth.uid
      && hasApprovedFriendRequestForUsers(request.resource.data.users[0], request.resource.data.users[1])
      && (
        (
          request.resource.data.users[0] < request.resource.data.users[1]
          && request.resource.data.pairId == ("pair:" + request.resource.data.users[0] + ":" + request.resource.data.users[1])
        )
        || (
          request.resource.data.users[1] < request.resource.data.users[0]
          && request.resource.data.pairId == ("pair:" + request.resource.data.users[1] + ":" + request.resource.data.users[0])
        )
      );
    }

    function hasApprovedFriendRequestForUsers(uidA, uidB) {
      let forwardRequestId = "pending:" + uidA + ":" + uidB;
      let reverseRequestId = "pending:" + uidB + ":" + uidA;
      return hasApprovedFriendRequestDoc(forwardRequestId, uidA, uidB)
        || hasApprovedFriendRequestDoc(reverseRequestId, uidB, uidA);
    }

    function hasApprovedFriendRequestDoc(requestId, senderUid, receiverUid) {
      return exists(/databases/$(database)/documents/friend_requests/$(requestId))
        && get(/databases/$(database)/documents/friend_requests/$(requestId)).data.status == "approved"
        && get(/databases/$(database)/documents/friend_requests/$(requestId)).data.senderUid == senderUid
        && get(/databases/$(database)/documents/friend_requests/$(requestId)).data.receiverUid == receiverUid
        && get(/databases/$(database)/documents/friend_requests/$(requestId)).data.respondedBy == receiverUid;
    }

    function isFriendshipSelfProfileUpdate() {
      return request.auth != null
      && resource != null
      && request.auth.uid in resource.data.users
      && request.resource.data.pairId == resource.data.pairId
      && request.resource.data.users == resource.data.users
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.createdBy == resource.data.createdBy
      && request.resource.data.profileByUid is map
      && request.resource.data.profileByUid.keys().hasOnly(resource.data.users)
      && isFriendshipProfileValue(request.resource.data.profileByUid[request.auth.uid])
      && (
        request.auth.uid == resource.data.users[0]
          ? request.resource.data.profileByUid[resource.data.users[1]] == resource.data.profileByUid[resource.data.users[1]]
          : request.resource.data.profileByUid[resource.data.users[0]] == resource.data.profileByUid[resource.data.users[0]]
      );
    }

    function friendshipPairId(uidA, uidB) {
      return uidA < uidB
        ? ("pair:" + uidA + ":" + uidB)
        : ("pair:" + uidB + ":" + uidA);
    }

    function friendshipExists(uidA, uidB) {
      return exists(/databases/$(database)/documents/friendships/$(friendshipPairId(uidA, uidB)));
    }

    function isSharedTaskSummaryV1(shareDocId) {
      return onlyKeys([
