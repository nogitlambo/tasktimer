      && (request.resource.data.taskCreatedAtMs == null || request.resource.data.taskCreatedAtMs is int)
      && (request.resource.data.dailyGoalMs == null || request.resource.data.dailyGoalMs is int)
      && request.resource.data.todayLoggedMs is int
      && request.resource.data.weekLoggedMs is int
      && (request.resource.data.weekGoalMs == null || request.resource.data.weekGoalMs is int)
      && request.resource.data.avgTimeLoggedThisWeekMs is int
      && request.resource.data.totalTimeLoggedMs is int
      && request.resource.data.sharedAt is timestamp
      && request.resource.data.updatedAt is timestamp
