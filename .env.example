# ==========================================
# TaskTimer example environment
# Copy to .env.local for local development.
# Do not put real secrets in this file.
# Values with NEXT_PUBLIC_ are exposed to the browser.
# ==========================================


# ==========================================
# Auth
# Server-only
# ==========================================
AUTH_SECRET=replace-with-a-long-random-string
AUTH_GOOGLE_ID=replace-with-google-oauth-client-id
AUTH_GOOGLE_SECRET=replace-with-google-oauth-client-secret


# ==========================================
# App URL
# Public
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ==========================================
# Firebase web app config
# Public: safe in browser, required for web auth/messaging
# Firebase Console -> Project settings -> Your apps -> Web app
# ==========================================
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-web-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-with-firebase-auth-domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace-with-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-with-firebase-storage-bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-with-firebase-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=replace-with-firebase-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=replace-with-firebase-measurement-id
NEXT_PUBLIC_FIREBASE_DATABASE_ID=timebase
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1


# ==========================================
# Firebase native/mobile runtime overrides
# Public if referenced by client code
# Keep only if you intentionally use separate mobile values
# ==========================================
NEXT_PUBLIC_FIREBASE_MOBILE_API_KEY=replace-with-android-firebase-api-key
NEXT_PUBLIC_FIREBASE_MOBILE_AUTH_DOMAIN=replace-with-mobile-auth-domain-if-needed


# ==========================================
# Firebase web push
# Public: browser-visible VAPID public key
# Firebase Console -> Project settings -> Cloud Messaging -> Web Push certificates
# ==========================================
NEXT_PUBLIC_FIREBASE_WEB_PUSH_VAPID_KEY=replace-with-web-push-vapid-public-key


# ==========================================
# Firebase App Check / local dev helpers
# Public in browser/dev usage
# ==========================================
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=replace-with-recaptcha-enterprise-site-key
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=replace-with-app-check-debug-token-if-needed


# ==========================================
# Firebase Admin SDK
# Server-only secrets
# ==========================================
FIREBASE_ADMIN_PROJECT_ID=replace-with-firebase-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=replace-with-service-account-client-email
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"


# ==========================================
# Stripe
# STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET are server-only
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is public
# ==========================================
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID_PRO_MONTHLY=price_replace_me


# ==========================================
# Misc backend integrations
# Server-only
# ==========================================
STITCH_API_KEY=replace-with-stitch-api-key


# ==========================================
# Jira feedback integration
# Server-only credentials
# BASE_URL and PROJECT_KEY are not secret, but can stay here for simplicity
# ==========================================
JIRA_BASE_URL=https://your-domain.atlassian.net/
JIRA_PROJECT_KEY=YOURPROJECT
JIRA_EMAIL=replace-with-jira-email
JIRA_API_TOKEN=replace-with-jira-api-token
