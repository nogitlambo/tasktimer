{
  "name": "tasktimer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\"",
    "dev": "next dev",
    "build": "npm run clean:next && next build --webpack",
    "postbuild": "node scripts/copy-standalone-assets.mjs",
    "build:android": "npm run clean:next && node scripts/build-android-export.mjs",
    "start": "next start",
    "lint": "node scripts/check-font-contract.mjs && eslint",
    "fonts:check": "node scripts/check-font-contract.mjs",
    "android:java:check": "node scripts/check-android-java.mjs",
    "android:sync": "npm run android:java:check && npm run build:android && npx cap sync android",
    "android:aab": "npm run android:sync && cd android && gradlew.bat bundleRelease",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug && copy /Y app\\build\\outputs\\apk\\debug\\app-debug.apk \"G:\\My Drive\\Apps\\app-debug.apk\"",
    "firebase:login": "npx firebase-tools login",
    "firebase:rules:deploy": "npx firebase-tools deploy --only firestore:rules --project tasktimer-prod",
    "firebase:login-and-rules:deploy": "npm run firebase:login && npm run firebase:rules:deploy",
    "docs:update": "node scripts/docs_sync.mjs --write",
    "docs:check": "node scripts/docs_sync.mjs --check",
    "docs:userguide:audit": "node scripts/userguide_feature_audit.mjs",
    "agents:update": "node scripts/docs_sync.mjs --write --target=agents",
    "agents:check": "node scripts/docs_sync.mjs --check --target=agents",
    "subscriptions:migrate": "node scripts/migrate-user-subscriptions.mjs",
    "subscriptions:reconcile-plans": "node scripts/reconcile-user-plans.mjs",
    "hooks:install": "node scripts/install_git_hooks.mjs",
    "test:recommend": "node scripts/recommend-tests.mjs",
    "test:unit": "vitest run",
    "test:unit:runtime": "vitest run src/app/tasktimer/client/confirm-actions.test.ts src/app/tasktimer/client/runtime-bridge.test.ts src/app/tasktimer/client/tasktimer-bootstrap.test.ts",
    "test:unit:schedule": "vitest run src/app/tasktimer/client/schedule-runtime.test.ts src/app/tasktimer/lib/schedule-placement.test.ts",
    "test:unit:history": "vitest run src/app/tasktimer/client/history-manager-generation.test.ts src/app/tasktimer/client/history-manager-shared.test.ts",
    "test:unit:archie": "vitest run src/app/api/archie/query/route.test.ts src/app/api/archie/recommendations/apply/route.test.ts src/app/api/archie/recommendations/draft/route.test.ts src/app/api/archie/recommendations/latest/route.test.ts src/app/api/archie/shared.drafts.test.ts src/app/api/archie/shared.test.ts src/app/tasktimer/lib/archieEngine.test.ts src/app/tasktimer/components/ArchieAssistantWidget.test.tsx",
    "test:unit:rewards": "vitest run src/app/tasktimer/lib/rewards.test.ts src/app/tasktimer/lib/focusInsights.test.ts src/app/tasktimer/lib/preferencesService.test.ts src/app/tasktimer/lib/pending-sync.test.ts src/app/tasktimer/lib/completionDifficulty.test.ts",
    "test:unit:subscriptions": "vitest run src/lib/subscriptionStore.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen http://127.0.0.1:3000",
    "test:e2e:auth:setup": "playwright test tests/e2e/auth.setup.ts --project=auth-setup --headed",
    "test:e2e:auth": "playwright test tests/e2e/authenticated.spec.ts --headed",
    "test:e2e:mobile": "playwright test tests/e2e/mobile-schedule.spec.ts --project=mobile-chromium --headed"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.1.0",
    "@capacitor/push-notifications": "^8.0.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/inconsolata": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@genkit-ai/google-genai": "^1.32.0",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "genkit": "^1.32.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
